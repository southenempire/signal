{
  "builds": [
    {
      "src": "apps/dashboard/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "apps/bot/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "apps/dashboard/app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "apps/dashboard/$1"
    }
  ]
}
